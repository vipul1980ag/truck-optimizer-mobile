# AI — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PayPal credentials — set these in Render Dashboard → Environment
# Get them from: https://developer.paypal.com → Apps & Credentials
PAYPAL_CLIENT_ID=your_live_client_id_here
PAYPAL_CLIENT_SECRET=your_live_client_secret_here
PAYPAL_ENV=live

# Data storage path (Render sets this to /data via render.yaml)
# DATA_PATH=/data

# Port is set automatically by Render — do NOT set this manually
# PORT=3000
